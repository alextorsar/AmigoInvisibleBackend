# pyenv
#   For a library or app, you might want to share your .python-version if you 'pin'
#   the version. For a library, it's not recommended.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different platforms, it may cause dependency mismatch.
#   Pipfile.lock

# poetry
#   poetry.lock is usually committed, but in some cases you might want to ignore it.
#   poetry.lock

# pdm
#   https://pdm.fming.dev/latest/usage/project/#gitignore
.pdm-plugins/
.pdm-python

# PEP 582; used by e.g. github.com/davidhalter/jedi to locate imports
__pypackages__/

